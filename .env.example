# SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your_app_password

# Sender name displayed in emails
FROM_NAME=Contract Radar

# Default recipient for all contract alerts (in addition to per-contract emails)
DEFAULT_ALERT_EMAIL=legal@yourcompany.com

# App URL used in email links
APP_URL=http://localhost:8002

# Database path
DB_PATH=contracts.db
