# Server
PORT=3000
NODE_ENV=production

# Database (defaults to in-memory)
DATABASE_URL=postgresql://user:pass@localhost:5432/contract_radar

# Email alerts (Resend, SendGrid, or SMTP)
RESEND_API_KEY=re_...
ALERT_FROM_EMAIL=alerts@contractradar.app
ALERT_REPLY_TO=support@contractradar.app

# Optional: Slack alerts
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Optional: OpenAI for better contract parsing
OPENAI_API_KEY=sk-...

# Auth (NextAuth.js for production)
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=http://localhost:3000
